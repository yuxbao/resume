<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="https://antfu.me/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="https://antfu.me/favicon.png" type="image/png" />
    <title>{{#if resume.name}}{{resume.name}}{{else}}Résumé{{/if}}</title>
    <script src="https://code.iconify.design/1/1.0.6/iconify.min.js"></script>
    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/3.2.0/css/bootstrap.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css?family=Noto+Sans+SC|Nunito+Sans:400,700&display=swap"
      rel="stylesheet"
    />
    <style>
      {{{css}}}
    </style>
  </head>

  <body itemscope itemtype="http://schema.org/Person">

    <div class="container">
      <section class="row">
        <div class="card-wrapper">
          <div class="card">
            <div class="profile-card">
              <div class="contact-details">
                <div class="name-and-profession">
                  <h3 class="text-bolder name" itemprop="name">
                    {{resume.name}}</h3>
                  <div
                    class="text-muted job"
                    itemprop="jobTitle"
                  >{{resume.title}}</div>
                </div>

                <div class="contact-info-row">
                  {{#if resume.personal_info.gender}}
                    <span class="detail">{{resume.personal_info.gender}}</span>
                  {{/if}}
                  {{#if resume.personal_info.age}}
                    <span class="detail separator-dot">
                      {{resume.personal_info.age}}
                      Years Old</span>
                  {{/if}}
                </div>

                {{#if resume.personal_info.phone}}
                  <div class="detail">
                    <a
                      href="tel://{{resume.personal_info.phone}}"
                      class="link-disguise info"
                      itemprop="telephone"
                      target="_blank"
                    >
                      <span class="iconify" data-icon="ri:phone-fill"></span>
                      {{resume.personal_info.phone}}
                    </a>
                  </div>
                {{/if}}

                {{#if resume.personal_info.email}}
                  <div class="detail">
                    <span class="info">
                      <a
                        href="mailto:{{resume.personal_info.email}}"
                        class="link-disguise"
                        itemprop="email"
                        target="_blank"
                      >
                        <span class="iconify" data-icon="ri:mail-fill"></span>
                        {{resume.personal_info.email}}
                      </a>
                    </span>
                  </div>
                {{/if}}

                {{#if resume.personal_info.wechat}}
                  <div class="detail">
                    <span class="info">
                      <span class="iconify" data-icon="ri:wechat-fill"></span>
                      {{resume.personal_info.wechat}}
                    </span>
                  </div>
                {{/if}}

                {{#if resume.personal_info.personal_blog}}
                  <div class="detail">
                    <span class="info">
                      <a
                        href="{{resume.personal_info.personal_blog}}"
                        class="link-disguise"
                        target="_blank"
                      >
                        <span class="iconify" data-icon="ri:global-line"></span>
                        {{resume.personal_info.personal_blog}}
                      </a>
                    </span>
                  </div>
                {{/if}}

              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="row page">
        <div class="card-wrapper">
          <div class="card background-card">

            <!-- Education -->
            {{#if resume.education}}
              <h4 id="education"><span class="title">Education</span></h4>
              <div class="card-nested" itemprop="description">
                <div class="content has-sidebar">
                  <div class="entry-heading">
                    <p class="clear-margin-sm entry-heading-main">
                      <strong>{{resume.education.degree}}</strong>
                      in
                      <strong>{{resume.education.major}}</strong>
                    </p>
                    <div class="entry-heading-side text-muted">
                      {{resume.education.duration}}
                    </div>
                  </div>
                  <p class="text-muted clear-margin-sm">
                    {{resume.education.institution}}
                    (Ranking:
                    {{resume.education.ranking}})
                  </p>

                  {{#if resume.education.relevant_courses}}
                    <div class="space-top labels">
                      <strong>Relevant Courses:</strong>
                      {{#each resume.education.relevant_courses}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}
                    </div>
                  {{/if}}

                  {{#if resume.education.achievements}}
                    <div class="subsection-block">
                      <strong>Achievements:</strong>
                      <ul class="highlight">
                        {{#each resume.education.achievements}}
                          <li>{{name}} - {{award}} ({{year}})</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}
                </div>
              </div>
            {{/if}}

            <div class="px10"></div>

            <!-- Intern Experience -->
            {{#if resume.intern_experience}}
              <div id="work-experience">
                <h4> <span class="title">Intern Experience</span> </h4>
                <ul class="list-unstyled">
                  {{#each resume.intern_experience}}
                    <li class="card-nested relax">
                      <div class="content has-sidebar">
                        <div class="entry-heading">
                          <div class="entry-heading-main">
                            <p class="clear-margin-sm">
                              <strong>{{company}}</strong>
                            </p>
                            <p
                              class="text-muted clear-margin-sm entry-subtitle"
                            >
                              {{role}}
                            </p>
                          </div>
                          <div class="entry-heading-side text-muted">
                            <small>{{duration}}</small>
                          </div>
                        </div>
                        {{#if tasks}}
                          <ul class="highlight">
                            {{#each tasks}}
                              <li>{{this}}</li>
                            {{/each}}
                          </ul>
                        {{/if}}
                      </div>
                    </li>
                  {{/each}}
                </ul>
              </div>
            {{/if}}

            <!-- Project Experience -->
            {{#if resume.project_experience}}
              <div id="projects">
                <h4><span class="title">Project Experience</span></h4>
                <ul class="list-unstyled projects">
                  {{#each resume.project_experience}}
                    <li class="card-nested relax">
                      <div class="content has-sidebar">
                        <div class="entry-heading">
                          <p class="clear-margin-sm entry-heading-main">
                            <strong>{{project_name}}</strong>
                          </p>
                          <div class="entry-heading-side text-muted">
                            <small>{{duration}}</small>
                          </div>
                        </div>

                        {{#if tech_stack}}
                          <p class="text-muted clear-margin-sm project-stack">
                            <small>Stack:
                              {{#each tech_stack}}{{this}}{{#unless @last}},
                                {{/unless}}{{/each}}</small>
                          </p>
                        {{/if}}

                        {{#if tasks}}
                          <ul class="highlight">
                            {{#each tasks}}
                              <li>{{this}}</li>
                            {{/each}}
                          </ul>
                        {{/if}}
                      </div>
                    </li>
                  {{/each}}
                </ul>
              </div>
            {{/if}}

            <!-- Skills & Certificates -->
            {{#if resume.skills_and_certificates}}
              <h4 id="skills"><span class="title">Skills & Certificates</span>
              </h4>
              <div class="card-nested" itemprop="description">
                <div class="skill-table">
                  {{#if resume.skills_and_certificates.languages}}
                    <div class="name">Languages</div>
                    <div class="skill-value">
                      {{#each resume.skills_and_certificates.languages}}
                        <strong>{{language}}:</strong>
                        {{proficiency}}
                        <br />
                        <small class="text-muted">{{description}}</small>
                      {{/each}}
                    </div>
                  {{/if}}

                  {{#if resume.skills_and_certificates.databases}}
                    <div class="name">Databases</div>
                    <div class="skill-value">
                      {{#each resume.skills_and_certificates.databases}}
                        {{database}}
                        ({{proficiency}}){{#unless @last}}, {{/unless}}
                      {{/each}}
                    </div>
                  {{/if}}

                  {{#if
                    resume.skills_and_certificates.system_design_and_deployment
                  }}
                    <div class="name">System Design</div>
                    <div class="skill-value">
                      <ul class="skill-list">
                        {{#each
                          resume.skills_and_certificates.system_design_and_deployment
                        }}
                          <li>{{this}}</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}

                  {{#if resume.skills_and_certificates.development_skills}}
                    <div class="name">Dev Skills</div>
                    <div class="skill-value">
                      <ul class="skill-list">
                        {{#each
                          resume.skills_and_certificates.development_skills
                        }}
                          <li>{{this}}</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}

                  {{#if resume.skills_and_certificates.others}}
                    <div class="name">Others</div>
                    <div class="skill-value">
                      <ul class="skill-list">
                        {{#each resume.skills_and_certificates.others}}
                          <li>{{this}}</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}

                </div>
              </div>
            {{/if}}

            <div class="resume-footer">
              <div class="detail no-print footer-links">
                <a
                  href="resume.pdf"
                  class="info"
                  itemprop="pdf"
                  target="_blank"
                >
                  English PDF
                </a>
                <span class="footer-divider">|</span>
                <a
                  href="resume-zh.pdf"
                  class="info"
                  itemprop="pdf"
                  target="_blank"
                >
                  Chinese PDF
                </a>
              </div>
              <div class="detail print-only footer-links">
                <a
                  href="https://resume.yux-bao.site"
                  class="info"
                  itemprop="pdf"
                  target="_blank"
                >
                  Online Version
                </a>
              </div>
              <div class="footer-updated">Last updated at
                {{getBuildDate ""}}</div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
